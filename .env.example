# Neo4j Content Graph
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Vector DB (Chroma uses local path by default)
CHROMA_PERSIST_DIR=./data/chroma

# Optional: LLM for enrichment (Ollama / OpenAI-compatible)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_ENABLED=false

# Telemetry / Event bus (stub)
EVENT_BUS_ENABLED=true
